snippet init
	\documentclass[a4paper,12pt]{article}
	\begin{document}
		\title{${1:title}}
		\author{Álvaro Candela}
		\date{2º Bach}
		\maketitle
	\pagestyle{plain}
	\end{document}

snippet box
	\fbox{%
	\parbox{\textwidth}{%
		${0:INSERT TEXT}
		%}
	}
snippet list
	\begin{itemize}
		\item ${0}
	\end{itemize}

snippet pg
	\newpage

snippet sec
	\section{${1:SECTION}}

snippet ssec
	\subsection{${1:SECTION}}

snippet sssec
	\subsubsection{${1:SECTION}}

snippet bd
	\textbf{${1:BOLD TEXT}}

snippet frac
	\frac{${2:DIVIDENDO}}{${1:DIVISOR}}
